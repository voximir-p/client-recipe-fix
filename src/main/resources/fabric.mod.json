{
  "schemaVersion": 1,
  "id": "client_recipe_fix",
  "version": "${version}",
  "name": "Client Recipe Fix",
  "description": "Grants JEI / REI access to vanilla recipes on server.",
  "authors": [
    "voximir"
  ],
  "contact": {
    "homepage": "https://modrinth.com/mod/client-recipe-fix",
    "sources": "https://github.com/voximir-p/client-recipe-fix",
    "issues": "https://github.com/voximir-p/client-recipe-fix/issues"
  },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "org.voximir.client_recipe_fix.client.ClientRecipeFixClient"
    ]
  },
  "accessWidener": "client_recipe_fix.accesswidener",
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.github_releases": "https://github.com/voximir-p/client-recipe-fix/releases",
        "modmenu.modrinth": "https://modrinth.com/mod/client-recipe-fix"
      }
    }
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "mixins": [
    "client_recipe_fix.mixins.json"
  ],
  "suggests": {
    "jei": "*",
    "roughlyenoughitems": "*"
  }
}
